# ── Anthropic ─────────────────────────────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# 분석에 사용할 모델 (기본: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# ── 뉴스 데이터 소스 (선택) ───────────────────────────────
# 가격 변동 원인 분석에 사용할 뉴스 API 키.
# 예: NewsAPI (https://newsapi.org)
NEWS_API_KEY=

# ── 서버 ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# 로그 레벨 (debug | info | warning | error)
LOG_LEVEL=info
